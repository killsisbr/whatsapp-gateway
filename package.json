{
  "name": "whatsapp-gateway",
  "version": "1.0.0",
  "description": "Centralized WhatsApp Gateway — um único Baileys socket para N projetos",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "qr": "tsx src/index.ts --qr-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cli": "tsx src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "bin": {
    "whatsapp-gateway": "./dist/cli.js"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@whiskeysockets/baileys": "^6.7.16",
    "bullmq": "^5.79.2",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "redis": "^6.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.0.5",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  }
}
